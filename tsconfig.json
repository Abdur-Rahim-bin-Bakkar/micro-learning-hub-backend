{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",

    "rootDir": "./src",
    "outDir": "./dist",

    "moduleResolution": "node",

    "strict": true,

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "sourceMap": true,

    "skipLibCheck": true
  },
  "include": ["src"]
}